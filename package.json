{
  "name": "bank_of_namibia_p2p",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for the Bank of Namibia IPN P2P integration challenge.",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0"
  },
  "scripts": {
    "start": "node scripts/start.mjs",
    "dev": "node scripts/start.mjs --no-open",
    "dev:all": "node scripts/start.mjs --no-open",
    "dev:api": "npm run dev -w @bon-p2p/api",
    "dev:web": "npm run dev -w @bon-p2p/web",
    "build": "npm run build:api && npm run build:web",
    "build:api": "npm run build -w @bon-p2p/api",
    "build:web": "npm run build -w @bon-p2p/web",
    "test": "npm run test:api",
    "test:api": "npm run test -w @bon-p2p/api",
    "test:web": "npm run test -w @bon-p2p/web -- --watch=false",
    "lint": "npm run lint:api && npm run lint:web",
    "lint:api": "npm run lint -w @bon-p2p/api",
    "lint:web": "npm run lint -w @bon-p2p/web"
  }
}
